# Backend env vars
# Copy to .env for local dev or set on Railway for production.

# Comma-separated list of origins allowed via CORS.
# Local dev default: http://localhost:5173,http://127.0.0.1:5173 (fallback in main.py)
# Production: set to your deployed frontend, e.g. https://twinmind-copilot.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173