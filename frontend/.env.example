# Frontend env vars (read by Vite at build time)
# Copy to .env.local for local dev with a custom backend, or set on Vercel for production.

# Backend API base URL.
# Local dev default: http://localhost:8000 (fallback in api.ts)
# Production: set to your deployed backend, e.g. https://twinmind-copilot-api.up.railway.app
VITE_API_BASE=http://localhost:8000